@{
    Layout = null;
    ViewBag.Title = "Register";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Librarium — Register</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="~/css/librarium-shared.css" rel="stylesheet" />

    <style>
        .pw-bar-wrap {
            height: 4px;
            background: #ede8de;
            border-radius: 2px;
            margin-top: 8px;
            overflow: hidden;
        }

        .pw-bar-fill {
            height: 100%;
            width: 0%;
            border-radius: 2px;
            transition: all 0.3s;
        }

        .pw-label {
            font-size: 11px;
            margin-top: 4px;
        }

        .pw-rules {
            font-size: 11px;
            color: #b8ac9a;
            margin-top: 6px;
            line-height: 1.9;
        }

        .pw-rule {
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .pw-rule.ok {
                color: #4a7a5c;
            }

        .match-msg {
            font-size: 11px;
            margin-top: 5px;
        }

        .login-screen {
            display: flex;
            align-items: flex-start;
            justify-content: center;
            min-height: 100vh;
            background: #f5f0e8;
            padding: 16px;
        }

        .login-right {
            width: 100% !important;
            max-width: 440px !important;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 12px 48px rgba(26,18,9,0.12);
            padding: 32px 24px;
            margin: 0 auto;
        }
    </style>

</head>
<body>
    <div class="login-screen">
        <div class="login-right">
            <div class="login-form-title">Create Account</div>
            <div class="login-form-sub">Join the library today</div>

            <div id="matchError" class="login-error" style="display:none;">
                ❌ Passwords do not match.
            </div>

            <!-- ✅ FORM -->
            <form method="post" action="/Auth/Register" onsubmit="return validateForm()">
                @Html.AntiForgeryToken()

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label">First Name</label>
                        <input class="form-input" name="FirstName" placeholder="John" required />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Last Name</label>
                        <input class="form-input" name="LastName" placeholder="Doe" required />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-input" name="Email" type="email" placeholder="your@email.com" required />
                </div>

                <div class="form-group">
                    <label class="form-label">Password</label>
                    <div style="position:relative;">
                        <input class="form-input"
                               name="Password"
                               id="regPassword"
                               type="password"
                               placeholder="Min. 8 characters"
                               minlength="8"
                               required
                               style="padding-right:42px;"
                               oninput="checkStrength(this.value)" />

                        <button type="button"
                                onclick="togglePw('regPassword','regEye')"
                                id="regEye"
                                style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;">
                            👁️
                        </button>
                    </div>

                    <div class="pw-bar-wrap">
                        <div class="pw-bar-fill" id="pwBar"></div>
                    </div>

                    <div class="pw-label" id="pwLabel">Enter a password</div>

                    <div class="pw-rules">
                        <div class="pw-rule" id="rule-len">○ At least 8 characters</div>
                        <div class="pw-rule" id="rule-upper">○ One uppercase letter</div>
                        <div class="pw-rule" id="rule-num">○ One number</div>
                        <div class="pw-rule" id="rule-special">○ One special character</div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Confirm Password</label>
                    <div style="position:relative;">
                        <input class="form-input"
                               name="ConfirmPassword"
                               id="confirmPassword"
                               type="password"
                               placeholder="Repeat your password"
                               required
                               style="padding-right:42px;"
                               oninput="checkMatch()" />

                        <button type="button"
                                onclick="togglePw('confirmPassword','confirmEye')"
                                id="confirmEye"
                                style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;">
                            👁️
                        </button>
                    </div>

                    <div class="match-msg" id="matchMsg"></div>
                </div>

                <button type="submit" class="btn-login sage">
                    Create Account →
                </button>
            </form>

            <p style="text-align:center;margin-top:16px;font-size:13px;color:#888;">
                Already have an account?
                <a href="/Auth/StudentLogin?direct=1">Login here</a>
            </p>

        </div>

    </div>
    <script>
        function togglePw(inputId, btnId) {
            var input = document.getElementById(inputId);
            var btn = document.getElementById(btnId);

            if (input.type === 'password') {
                input.type = 'text';
                btn.textContent = '🙈';
            } else {
                input.type = 'password';
                btn.textContent = '👁️';
            }
        }

        function checkStrength(pw) {
            var len = pw.length >= 8;
            var upper = /[A-Z]/.test(pw);
            var num = /[0-9]/.test(pw);
            var spec = /[^A-Za-z0-9]/.test(pw);

            var score = [len, upper, num, spec].filter(Boolean).length;

            var bar = document.getElementById('pwBar');
            var label = document.getElementById('pwLabel');

            var colors = ['', '#7a2020', '#d4860a', '#c8842a', '#4a7a5c'];
            var labels = ['', 'Weak', 'Fair', 'Good', 'Strong'];
            var widths = ['0%', '25%', '50%', '75%', '100%'];

            bar.style.width = pw.length === 0 ? '0%' : widths[score];
            bar.style.background = colors[score] || '#ede8de';
            label.textContent = pw.length === 0 ? 'Enter a password' : labels[score];
            label.style.color = colors[score] || '#b8ac9a';

            checkMatch();
        }

        function checkMatch() {
            var pw = document.getElementById('regPassword').value;
            var confirm = document.getElementById('confirmPassword').value;
            var msg = document.getElementById('matchMsg');

            if (confirm.length === 0) {
                msg.textContent = '';
                return;
            }

            if (pw === confirm) {
                msg.textContent = '✅ Passwords match';
                msg.style.color = '#4a7a5c';
            } else {
                msg.textContent = '❌ Passwords do not match';
                msg.style.color = '#7a2020';
            }
        }

        function validateForm() {
            var pw = document.getElementById('regPassword').value;
            var confirm = document.getElementById('confirmPassword').value;
            var err = document.getElementById('matchError');

            if (pw !== confirm) {
                err.style.display = 'block';
                return false;
            }

            err.style.display = 'none';
            return true;
        }
    </script>
</body>
</html>