@{
    Layout = null;
    ViewBag.Title = "Admin Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Librarium — Admin Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="~/css/librarium-shared.css" rel="stylesheet" />
</head>
<body>
    <div class="login-screen">
        <div class="login-left">
            <div class="login-brand">
                <span class="login-brand-name">Librarium</span>
                <span class="login-brand-tagline">Library Management System</span>
            </div>
            <div class="login-deco">📚</div>
        </div>
        <div class="login-right">
            <div class="login-form-title">Admin Login</div>
            <div class="login-form-sub">Manage books, members &amp; borrowing</div>
            @if (ViewBag.Error != null)
            {
                <div class="login-error" style="display:block">❌ @ViewBag.Error</div>
            }
            <form method="post" action="/Auth/AdminLogin">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Username</label>
                    <input class="form-input" name="username" type="text" placeholder="Enter admin username" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input class="form-input" name="password" type="password" placeholder="Enter password" required />
                </div>
                <button type="submit" class="btn-login">Login as Admin →</button>
                <a href="/Admin/ForgotPassword" style="display:block;text-align:center;margin-top:12px;font-size:12px;color:var(--amber);">Forgot password?</a>
            </form>
        </div>
    </div>
</body>
</html>
