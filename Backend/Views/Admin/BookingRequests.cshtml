@model List<Librarium.Models.BookingRequest>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Booking Requests";
    ViewBag.PageName = "BookingRequests";

    var returnRequests = (ViewBag.ReturnRequests as IEnumerable<Librarium.Models.ReturnRequest>)?.ToList() ?? new List<Librarium.Models.ReturnRequest>();

    // Build unique member names from both lists for autocomplete
    var memberNames = Model
        .Select(r => r.StudentName)
        .Concat(returnRequests.Select(r => r.StudentName))
        .Where(n => !string.IsNullOrWhiteSpace(n))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(n => n)
        .ToList();
}
<style>
    .request-card, .return-card {
        background: #fff;
        border: 1px solid var(--paper);
    }

    body.dark .request-card,
    body.dark .return-card {
        background: #1e1a16 !important;
        border-color: #2e2720;
        box-shadow: 0 1px 6px rgba(0,0,0,0.3);
    }

    body.dark #searchWrap {
        background: #1e1a16 !important;
        border-color: #2e2720 !important;
    }

    body.dark #memberSearch {
        color: #e8ddd0;
    }

    body.dark #autocompleteList {
        background: #1e1a16;
        border-color: #2e2720;
    }
</style>
@* ── Search Bar ── *@
<div style="max-width:900px;margin:0 auto 0;padding:20px 20px 0;">
    <div style="position:relative;margin-bottom:24px;">
        <div id="searchWrap" style="display:flex;align-items:center;gap:10px;background:#fff;border:1.5px solid var(--paper);border-radius:10px;padding:10px 16px;transition:all 0.2s;">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;">
                <circle cx="6.5" cy="6.5" r="5" stroke="var(--dust)" stroke-width="1.3" />
                <line x1="10.5" y1="10.5" x2="14" y2="14" stroke="var(--dust)" stroke-width="1.3" stroke-linecap="round" />
            </svg>
            <input id="memberSearch"
                   type="text"
                   placeholder="Search by member name…"
                   autocomplete="off"
                   style="flex:1;border:none;outline:none;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--ink);background:transparent;" />
            <button id="clearSearch" onclick="clearSearch()" style="display:none;background:none;border:none;cursor:pointer;font-size:16px;color:var(--dust);line-height:1;padding:0 2px;" aria-label="Clear">✕</button>
        </div>

        <ul id="autocompleteList" style="display:none;position:absolute;top:calc(100% + 6px);left:0;right:0;background:#fff;border:1.5px solid var(--paper);border-radius:10px;overflow:hidden;z-index:200;list-style:none;padding:4px 0;box-shadow:0 6px 20px rgba(26,18,9,0.1);">
        </ul>

        <div id="activeFilter" style="display:none;margin-top:10px;">
            <span id="filterChip" style="display:inline-flex;align-items:center;gap:8px;background:var(--ink);color:#fff;border-radius:999px;padding:5px 14px;font-size:13px;font-family:'DM Sans',sans-serif;">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="5" r="3" stroke="white" stroke-width="1.3" /><path d="M2 14c0-3 2.7-5 6-5s6 2 6 5" stroke="white" stroke-width="1.3" stroke-linecap="round" /></svg>
                <span id="filterChipName"></span>
                <button onclick="clearFilter()" style="background:none;border:none;color:rgba(255,255,255,0.65);cursor:pointer;font-size:14px;padding:0;line-height:1;" aria-label="Remove filter">✕</button>
            </span>
        </div>
    </div>
</div>

@* ── Booking Requests ── *@
<div style="max-width:900px;margin:0 auto;padding:0 20px;">
    <h3 style="margin-bottom:20px;">📋 Booking Requests</h3>

    @if (!Model.Any())
    {
        <div style="text-align:center;color:#aaa;padding:60px 0;">No booking requests yet.</div>
    }
    else
    {
        @foreach (var r in Model)
        {
            <div id="row-@r.Id" class="request-card" data-member="@r.StudentName.ToLower()"
                 style="background:#fff;border-radius:12px;padding:16px 20px;margin-bottom:14px;box-shadow:0 1px 6px rgba(0,0,0,0.07);">
                <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
                    <div>
                        <div style="font-weight:600;font-size:15px;">@r.BookTitle</div>
                        <div style="font-size:13px;color:#555;margin-top:2px;">👤 @r.StudentName — @r.StudentEmail</div>
                        <div style="font-size:12px;color:#888;margin-top:2px;">Requested: @r.RequestedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</div>
                        @if (!string.IsNullOrEmpty(r.AdminNote))
                        {
                            <div style="font-size:12px;color:#666;margin-top:4px;">Note: @r.AdminNote</div>
                        }
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                        @if (r.Status == "pending")
                        {
                            <span style="background:#fff3cd;color:#856404;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;">⏳ Pending</span>
                            <input type="text" id="note-@r.Id" placeholder="Optional note..." style="padding:6px 10px;border:1px solid #ddd;border-radius:6px;font-size:13px;width:160px;" />
                            <button onclick="handleBooking(@r.Id, 'approve')" style="background:#2d6a4f;color:#fff;border:none;padding:7px 14px;border-radius:6px;cursor:pointer;font-size:13px;">✅ Approve</button>
                            <button onclick="handleBooking(@r.Id, 'reject')" style="background:#c0392b;color:#fff;border:none;padding:7px 14px;border-radius:6px;cursor:pointer;font-size:13px;">❌ Reject</button>
                        }
                        else if (r.Status == "approved")
                        {
                            <span style="background:#d1e7dd;color:#0a3622;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;">✅ Approved</span>
                        }
                        else
                        {
                            <span style="background:#f8d7da;color:#842029;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;">❌ Rejected</span>
                        }
                    </div>
                </div>
            </div>
        }

        <div id="bookingEmpty" style="display:none;text-align:center;color:#aaa;padding:40px 0;font-size:14px;">No booking requests for this member.</div>
    }
</div>

@* ── Return Requests ── *@
<div style="max-width:900px;margin:20px auto 0;padding:0 20px 20px;">
    <h3 style="margin-bottom:20px;">📬 Return Requests</h3>
    @if (!returnRequests.Any())
    {
        <div style="text-align:center;color:#aaa;padding:40px 0;">No return requests yet.</div>
    }
    else
    {
        @foreach (var r in returnRequests)
        {
            <div id="ret-row-@r.Id" class="return-card" data-member="@r.StudentName.ToLower()"
                 style="background:#fff;border-radius:12px;padding:16px 20px;margin-bottom:14px;box-shadow:0 1px 6px rgba(0,0,0,0.07);">
                <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
                    <div>
                        <div style="font-weight:600;font-size:15px;">@r.BookTitle</div>
                        <div style="font-size:13px;color:#555;margin-top:2px;">👤 @r.StudentName — @r.StudentEmail</div>
                        <div style="font-size:12px;color:#888;margin-top:2px;">Requested: @r.RequestedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</div>
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                        @if (r.Status == "pending")
                        {
                            <span style="background:#fff3cd;color:#856404;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;">⏳ Pending</span>
                            <button onclick="handleReturn(@r.Id, 'approve')" style="background:#2d6a4f;color:#fff;border:none;padding:7px 14px;border-radius:6px;cursor:pointer;font-size:13px;">✅ Approve</button>
                            <button onclick="handleReturn(@r.Id, 'reject')" style="background:#c0392b;color:#fff;border:none;padding:7px 14px;border-radius:6px;cursor:pointer;font-size:13px;">❌ Reject</button>
                        }
                        else if (r.Status == "approved")
                        {
                            <span style="background:#d1e7dd;color:#0a3622;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;">✅ Approved</span>
                        }
                        else
                        {
                            <span style="background:#f8d7da;color:#842029;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;">❌ Rejected</span>
                        }
                    </div>
                </div>
            </div>
        }
        <div id="returnEmpty" style="display:none;text-align:center;color:#aaa;padding:40px 0;font-size:14px;">No return requests for this member.</div>
    }
</div>

<div id="toast" style="display:none;position:fixed;bottom:24px;right:24px;padding:12px 20px;border-radius:10px;color:#fff;font-size:14px;z-index:999;box-shadow:0 4px 16px rgba(0,0,0,0.15);"></div>

@Html.AntiForgeryToken()

<script>
    // ── Member names from server (name-only, deduplicated) ──
    const allMembers = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(memberNames)
        );

    const input        = document.getElementById('memberSearch');
    const list         = document.getElementById('autocompleteList');
    const clearBtn     = document.getElementById('clearSearch');
    const activeFilter = document.getElementById('activeFilter');
    const chipName     = document.getElementById('filterChipName');
    const searchWrap   = document.getElementById('searchWrap');

    let activeIndex = -1;
    let currentFilter = null;

    // Focus styling
    input.addEventListener('focus', () => searchWrap.style.borderColor = 'var(--amber)');
    input.addEventListener('blur',  () => { setTimeout(closeList, 150); searchWrap.style.borderColor = 'var(--paper)'; });

    input.addEventListener('input', () => {
        const q = input.value.trim();
        clearBtn.style.display = q ? 'block' : 'none';
        renderList(q);
    });

    input.addEventListener('keydown', e => {
        const items = list.querySelectorAll('li');
        if (e.key === 'ArrowDown') { e.preventDefault(); activeIndex = Math.min(activeIndex + 1, items.length - 1); highlight(items); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); activeIndex = Math.max(activeIndex - 1, 0); highlight(items); }
        else if (e.key === 'Enter' && activeIndex >= 0) { e.preventDefault(); selectMember(items[activeIndex].dataset.name); }
        else if (e.key === 'Escape') closeList();
    });

    function highlight(items) {
        items.forEach((li, i) => {
            li.style.background = i === activeIndex ? 'var(--paper)' : '';
            li.style.color      = i === activeIndex ? 'var(--ink)' : '';
        });
    }

    function renderList(q) {
        activeIndex = -1;
        if (!q) { closeList(); return; }

        const matches = allMembers.filter(n => n.toLowerCase().includes(q.toLowerCase()));
        if (!matches.length) {
            list.innerHTML = '<li style="padding:10px 16px;font-size:13px;color:var(--dust);font-family:\'DM Sans\',sans-serif;">No members found</li>';
            list.style.display = 'block';
            return;
        }

        list.innerHTML = matches.map(name => {
            const idx   = name.toLowerCase().indexOf(q.toLowerCase());
            const before = name.slice(0, idx);
            const match  = name.slice(idx, idx + q.length);
            const after  = name.slice(idx + q.length);
            return `<li data-name="${name}"
                style="padding:10px 16px;font-size:13px;cursor:pointer;font-family:'DM Sans',sans-serif;display:flex;align-items:center;gap:10px;transition:background 0.1s;"
                onmouseenter="this.style.background='var(--paper)'" onmouseleave="this.style.background=''">
                <span style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--amber),var(--burgundy));display:inline-flex;align-items:center;justify-content:center;font-size:11px;color:#fff;font-weight:600;flex-shrink:0;">${getInitials(name)}</span>
                <span>${before}<strong>${match}</strong>${after}</span>
            </li>`;
        }).join('');

        list.querySelectorAll('li[data-name]').forEach(li => {
            li.addEventListener('mousedown', e => { e.preventDefault(); selectMember(li.dataset.name); });
        });
        list.style.display = 'block';
    }

    function selectMember(name) {
        currentFilter = name.toLowerCase();
        input.value = '';
        clearBtn.style.display = 'none';
        closeList();
        chipName.textContent = name;
        activeFilter.style.display = 'block';
        applyFilter(currentFilter);
    }

    function clearSearch() {
        input.value = '';
        clearBtn.style.display = 'none';
        closeList();
    }

    function clearFilter() {
        currentFilter = null;
        activeFilter.style.display = 'none';
        document.querySelectorAll('.request-card, .return-card').forEach(c => c.style.display = '');
        document.getElementById('bookingEmpty').style.display = 'none';
        document.getElementById('returnEmpty').style.display  = 'none';
    }

    function applyFilter(key) {
        let bookVisible = 0, retVisible = 0;
        document.querySelectorAll('.request-card').forEach(c => {
            const show = c.dataset.member === key;
            c.style.display = show ? '' : 'none';
            if (show) bookVisible++;
        });
        document.querySelectorAll('.return-card').forEach(c => {
            const show = c.dataset.member === key;
            c.style.display = show ? '' : 'none';
            if (show) retVisible++;
        });
        document.getElementById('bookingEmpty').style.display = bookVisible === 0 ? 'block' : 'none';
        document.getElementById('returnEmpty').style.display  = retVisible  === 0 ? 'block' : 'none';
    }

    function closeList() { list.style.display = 'none'; activeIndex = -1; }

    function getInitials(name) {
        return name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
    }

    document.addEventListener('click', e => {
        if (!e.target.closest('#searchWrap') && !e.target.closest('#autocompleteList')) closeList();
    });

    // ── Booking / Return handlers (unchanged) ──
    function handleBooking(id, action) {
        var note = document.getElementById('note-' + id)?.value ?? '';
        var url  = action === 'approve' ? '/Admin/ApproveBooking' : '/Admin/RejectBooking';
        fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            },
            body: 'id=' + id + '&adminNote=' + encodeURIComponent(note)
        })
        .then(r => r.json())
        .then(data => { showToast(data.message, data.success); if (data.success) setTimeout(() => location.reload(), 1500); })
        .catch(() => showToast('Something went wrong.', false));
    }

    function handleReturn(id, action) {
        var url = action === 'approve' ? '/Admin/ApproveReturn' : '/Admin/RejectReturn';
        fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            },
            body: 'id=' + id
        })
        .then(r => r.json())
        .then(data => { showToast(data.message, data.success); if (data.success) setTimeout(() => location.reload(), 1500); })
        .catch(() => showToast('Something went wrong.', false));
    }

    function showToast(msg, success) {
        var t = document.getElementById('toast');
        t.textContent = msg;
        t.style.background = success ? '#2d6a4f' : '#c0392b';
        t.style.display = 'block';
        setTimeout(() => t.style.display = 'none', 3000);
    }
</script>
