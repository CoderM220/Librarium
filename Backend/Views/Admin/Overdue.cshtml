@model IEnumerable<Librarium.Models.BorrowRecord>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Overdue";
    ViewBag.PageName = "Overdue";
}

<div class="panel">
    <div class="panel-header">
        <span class="panel-title">⚠️ Overdue Books</span>
        <span style="font-size:13px;color:var(--burgundy);">@Model.Count() overdue record@(Model.Count() != 1 ? "s" : "")</span>
    </div>

    @if (!Model.Any())
    {
        <p style="color:#aaa;text-align:center;padding:32px;">🎉 No overdue books right now!</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Book</th>
                    <th>Member</th>
                    <th>Due Date</th>
                    <th>Days Overdue</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    var daysLate = (DateTime.Today - r.DueDate.Date).Days;
                    <tr>
                        <td>
                            <div class="book-cell">
                                <div class="book-thumb">📖</div>
                                <div><span class="book-t">@r.BookTitle</span></div>
                            </div>
                        </td>
                        <td>
                            <div>
                                <span class="book-t">@r.StudentName</span>
                                <span class="book-a">@r.StudentEmail</span>
                            </div>
                        </td>
                        <td style="color:var(--burgundy);font-size:13px;">@r.DueDate.ToString("MMM d, yyyy")</td>
                        <td>
                            <span class="badge" style="background:var(--burgundy);color:#fff;">@daysLate day@(daysLate != 1 ? "s" : "") late</span>
                        </td>
                        <td>
                            <button onclick="returnBook(@r.Id, '@r.BookTitle.Replace("'", "\\'")')" class="btn btn-outline" style="font-size:12px;padding:4px 10px;">✅ Mark Returned</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<script>
    function returnBook(recordId, title) {
        if (!confirm(`Mark "${title}" as returned?`)) return;
        fetch(`/Admin/ReturnBook/${recordId}`, { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if (data.success) location.reload();
                else alert('Something went wrong.');
            });
    }
</script>
