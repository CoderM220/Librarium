@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Forgot Password";
}

<div style="max-width:420px;margin:60px auto;">
    <div style="background:#fff;border:1px solid var(--paper);border-radius:14px;padding:28px 32px;">
        <h4 style="font-family:'Playfair Display',serif;color:var(--ink);margin:0 0 6px;">Forgot Password</h4>
        <p style="font-size:13px;color:var(--dust);margin:0 0 20px;">Enter your admin email and we'll send you an OTP.</p>

        @if (ViewBag.Error != null)
        {
            <div style="background:rgba(122,32,32,0.08);border:1px solid rgba(122,32,32,0.2);border-radius:8px;padding:10px 14px;font-size:13px;color:var(--burgundy);margin-bottom:14px;">❌ @ViewBag.Error</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Email Address</label>
                <input type="email" name="email" class="form-input" placeholder="admin@example.com" required autofocus />
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;margin-top:8px;">Send OTP</button>
            <a href="/Auth/AdminLogin" class="btn btn-outline" style="width:100%;margin-top:8px;text-align:center;display:block;">Back to Login</a>
        </form>
    </div>
</div>