@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Issue Book";
    ViewBag.PageName = "Borrowing";

    var books = ViewBag.Books as List<Librarium.Models.Book>;
    var students = ViewBag.Students as List<Librarium.Models.Student>;
}

<div class="panel" style="max-width:560px;">
    <div class="panel-header">
        <span class="panel-title">📤 Issue Book to Member</span>
        <a href="/Admin/Borrowing" class="btn btn-outline">← Back</a>
    </div>

    <form method="post" action="/Admin/IssueBook" style="padding:8px 0;">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label">Select Book *</label>
            <select class="form-input" name="bookId" required>
                <option value="">— Choose a book —</option>
                @foreach (var b in books!)
                {
                    <option value="@b.Id">@b.Emoji @b.Title — @b.Author (@b.AvailableCopies available)</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Select Member *</label>
            <select class="form-input" name="studentId" required>
                <option value="">— Choose a member —</option>
                @foreach (var s in students!)
                {
                    <option value="@s.Id">@s.FullName (@s.Email)</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Loan Duration</label>
            <select class="form-input" name="dueDays" style="max-width:200px;">
                <option value="7">7 days</option>
                <option value="14" selected>14 days (default)</option>
                <option value="21">21 days</option>
                <option value="30">30 days</option>
            </select>
        </div>

        <div style="display:flex;gap:10px;margin-top:16px;">
            <button type="submit" class="btn btn-primary">📤 Issue Book</button>
            <a href="/Admin/Borrowing" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
