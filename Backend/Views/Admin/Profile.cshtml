@model Librarium.Models.AdminUser
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Profile";
    ViewBag.PageName = "Profile";
}

<style>
    .pro-hero {
        background: linear-gradient(135deg, #1a1209 0%, #3a2010 100%);
        border-radius: 16px;
        padding: 24px 28px;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .pro-ava {
        width: 68px;
        height: 68px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--amber), var(--burgundy));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: 600;
        color: #fff;
        border: 3px solid rgba(232,168,74,0.35);
        flex-shrink: 0;
    }

    .pro-type {
        font-size: 10px;
        letter-spacing: 0.18em;
        color: #b8ac9a;
        text-transform: uppercase;
        margin: 0 0 3px;
    }

    .pro-name {
        font-size: 19px;
        font-weight: 600;
        color: #e8a84a;
        margin: 0 0 3px;
    }

    .pro-email {
        font-size: 12px;
        color: #c4a97a;
        margin: 0;
    }

    .pro-stats {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 10px;
        margin-bottom: 14px;
    }

    .pro-stat {
        background: #fff;
        border: 1px solid var(--paper);
        border-radius: 12px;
        padding: 12px 16px;
    }

    .pro-stat-v {
        font-size: 22px;
        font-weight: 700;
        margin: 0 0 2px;
        font-family: 'Playfair Display', serif;
    }

    .pro-stat-l {
        font-size: 11px;
        color: var(--dust);
        margin: 0;
    }

    .pro-card {
        background: #fff;
        border: 1px solid var(--paper);
        border-radius: 14px;
        overflow: hidden;
        max-width: 560px;
    }

    .pro-tabs {
        display: flex;
        border-bottom: 1px solid var(--paper);
    }

    .pro-tab {
        flex: 1;
        padding: 12px;
        font-size: 13px;
        font-weight: 500;
        border: none;
        background: transparent;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        color: #888;
        font-family: 'DM Sans', sans-serif;
    }

        .pro-tab.on {
            border-bottom-color: var(--amber);
            color: var(--amber);
        }

    .pro-body {
        padding: 20px 24px;
    }

    .pro-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid var(--paper);
        font-size: 13px;
    }

        .pro-row:last-child {
            border-bottom: none;
        }

    .pro-lbl {
        color: var(--dust);
        font-size: 11px;
    }

    .pro-val {
        color: var(--ink);
        font-weight: 500;
    }

    .pro-edit-btn {
        font-size: 11px;
        padding: 4px 12px;
        border-radius: 20px;
        border: 1px solid var(--paper);
        background: transparent;
        color: var(--dust);
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
    }

    .pro-expand {
        border-top: 1px solid var(--paper);
        padding: 18px 24px;
        display: none;
    }

        .pro-expand.open {
            display: block;
        }

    .pro-chpw-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--amber);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        margin: 4px 0 14px;
        font-family: 'DM Sans', sans-serif;
    }

    .pro-chpw-section {
        display: none;
        border-top: 1px solid var(--paper);
        padding-top: 14px;
    }

        .pro-chpw-section.open {
            display: block;
        }

    .pro-arrow {
        display: inline-block;
        transition: transform 0.2s;
        font-style: normal;
    }

        .pro-arrow.open {
            transform: rotate(180deg);
        }

    .pro-setting-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid var(--paper);
    }

        .pro-setting-row:last-child {
            border-bottom: none;
        }

    .pro-setting-lbl {
        font-size: 13px;
        color: var(--ink);
    }

    .pro-setting-sub {
        font-size: 11px;
        color: var(--dust);
        margin-top: 1px;
    }

    .pro-toggle {
        width: 36px;
        height: 20px;
        border-radius: 10px;
        position: relative;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.2s;
    }

        .pro-toggle.on {
            background: var(--amber);
        }

        .pro-toggle.off {
            background: var(--paper);
        }

    .pro-knob {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: #fff;
        position: absolute;
        top: 2px;
        transition: left 0.2s;
    }

    .pro-toggle.on .pro-knob {
        left: 18px;
    }

    .pro-toggle.off .pro-knob {
        left: 2px;
    }

    .pro-section-lbl {
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--dust);
        margin: 0 0 10px;
    }
</style>

@{
    var db = Context.RequestServices.GetService<Librarium.Models.LibrariumDbContext>()!;
    var studentId = Context.Session.GetInt32("AdminId");
    var totalBorrows = db.BorrowRecords.Count();
    var activeBorrows = db.BorrowRecords.Count(r => r.Status == "active");
    var overdueCount = db.BorrowRecords.Count(r => r.Status == "overdue");
}

<div class="pro-hero">
    <div class="pro-ava">@Model.Username.Substring(0, Math.Min(2, Model.Username.Length)).ToUpper()</div>
    <div>
        <p class="pro-type">Account Type — Admin</p>
        <p class="pro-name">@Model.Username</p>
        <p class="pro-email">@Model.Email</p>
    </div>
</div>

<div class="pro-stats">
    <a href="/Admin/Borrowing" style="text-decoration:none;">
        <div class="pro-stat">
            <p class="pro-stat-v" style="color:var(--ink);">@totalBorrows</p>
            <p class="pro-stat-l">Total Borrows</p>
        </div>
    </a>
    <a href="/Admin/Borrowing" style="text-decoration:none;">
        <div class="pro-stat">
            <p class="pro-stat-v" style="color:var(--sage);">@activeBorrows</p>
            <p class="pro-stat-l">Active Books</p>
        </div>
    </a>
    <a href="/Admin/Overdue" style="text-decoration:none;">
        <div class="pro-stat">
            <p class="pro-stat-v" style="color:var(--burgundy);">@overdueCount</p>
            <p class="pro-stat-l">Overdue</p>
        </div>
    </a>
</div>

<div class="pro-card">
    <div class="pro-tabs">
        <button class="pro-tab on" id="tab-info" onclick="showTab('info')">Account Info</button>
        <button class="pro-tab" id="tab-settings" onclick="showTab('settings')">Settings</button>
    </div>

    <div id="pane-info">
        <div class="pro-body">
            <div class="pro-row"><span class="pro-lbl">Account Type</span><span class="pro-val">Admin</span></div>
            <div class="pro-row"><span class="pro-lbl">Username</span><span class="pro-val">@Model.Username</span></div>
            <div class="pro-row"><span class="pro-lbl">Email</span><span class="pro-val">@Model.Email</span></div>
            <div class="pro-row" style="border-bottom:none;">
                <span class="pro-lbl">Edit Profile</span>
                <button class="pro-edit-btn" onclick="toggleEdit()">Edit ✏️</button>
            </div>
        </div>

        <div class="pro-expand" id="edit-expand">
            @if (TempData["PwSuccess"] != null)
            {
                <div style="background:rgba(74,122,92,0.1);border:1px solid rgba(74,122,92,0.25);border-radius:8px;padding:10px 14px;font-size:13px;color:var(--sage);margin-bottom:14px;">✅ @TempData["PwSuccess"]</div>
            }
            @if (TempData["PwError"] != null)
            {
                <div style="background:rgba(122,32,32,0.08);border:1px solid rgba(122,32,32,0.2);border-radius:8px;padding:10px 14px;font-size:13px;color:var(--burgundy);margin-bottom:14px;">❌ @TempData["PwError"]</div>
            }
            <form method="post" action="/Admin/ChangePassword">
                @Html.AntiForgeryToken()
                <p style="font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--dust);margin-bottom:10px;">Edit Profile</p>
                <div class="form-group">
                    <label class="form-label">Username</label>
                    <input class="form-input" name="username" value="@Model.Username" />
                </div>
                <div style="height:1px;background:var(--paper);margin:16px 0 4px;"></div>
                <button type="button" class="pro-chpw-btn" onclick="toggleChpw()">
                    <span class="pro-arrow" id="chpwArrow">▼</span> Change Password
                </button>
                <div class="pro-chpw-section" id="chpwSection">
                <div class="form-group">
                    <label class="form-label">Current Password</label>
                    <div style="position:relative;">
                        <input class="form-input" id="curPw" name="currentPassword" type="password" placeholder="Enter current password" style="padding-right:42px;" />
                        <button type="button" onclick="togglePw('curPw',this)" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:15px;color:var(--dust);padding:0;">👁️</button>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">New Password</label>
                    <div style="position:relative;">
                        <input class="form-input" id="newPw" name="newPassword" type="password" placeholder="Min 8 characters" style="padding-right:42px;" />
                        <button type="button" onclick="togglePw('newPw',this)" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:15px;color:var(--dust);padding:0;">👁️</button>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Confirm New Password</label>
                    <div style="position:relative;">
                        <input class="form-input" id="conPw" name="confirmPassword" type="password" placeholder="Repeat new password" style="padding-right:42px;" />
                        <button type="button" onclick="togglePw('conPw',this)" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:15px;color:var(--dust);padding:0;">👁️</button>
                    </div>
                </div>
                    <a href="/Admin/ForgotPassword" style="font-size:12px;color:var(--amber);display:inline-block;margin-bottom:14px;">Forgot password?</a>
                </div>
                    <button type="submit" class="btn btn-primary" style="margin-top:8px;">💾 Save Changes</button>
                    <button type="button" onclick="toggleEdit()" class="btn btn-outline" style="margin-top:8px;margin-left:8px;">Cancel</button>
            </form>
        </div>
    </div>

    <div id="pane-settings" style="display:none;">
        <div class="pro-body">
            <p class="pro-section-lbl">Appearance</p>
            <div class="pro-setting-row">
                <div><div class="pro-setting-lbl">Dark Mode</div><div class="pro-setting-sub">Switch to dark theme</div></div>
                <div class="pro-toggle off" id="darkToggle" onclick="toggleDark()"><div class="pro-knob"></div></div>
            </div>
            <p class="pro-section-lbl" style="margin-top:16px;">Notifications</p>
            <div class="pro-setting-row">
                <div><div class="pro-setting-lbl">New Booking Requests</div><div class="pro-setting-sub">Alert when a student submits a request</div></div>
                <div class="pro-toggle on" id="bookingToggle" onclick="toggleSetting('bookingToggle')"><div class="pro-knob"></div></div>
            </div>
            <div class="pro-setting-row">
                <div><div class="pro-setting-lbl">Overdue Reminders</div><div class="pro-setting-sub">Daily digest of overdue books</div></div>
                <div class="pro-toggle off" id="overdueToggle" onclick="toggleSetting('overdueToggle')"><div class="pro-knob"></div></div>
            </div>
        </div>
    </div>
</div>

<script>
    function showTab(name) {
        document.getElementById('pane-info').style.display = name === 'info' ? 'block' : 'none';
        document.getElementById('pane-settings').style.display = name === 'settings' ? 'block' : 'none';
        document.getElementById('tab-info').classList.toggle('on', name === 'info');
        document.getElementById('tab-settings').classList.toggle('on', name === 'settings');
    }
    function toggleEdit() {
        document.getElementById('edit-expand').classList.toggle('open');
    }
    function toggleChpw() {
        document.getElementById('chpwSection').classList.toggle('open');
        document.getElementById('chpwArrow').classList.toggle('open');
    }
    function togglePw(id, btn) {
        var inp = document.getElementById(id);
        inp.type = inp.type === 'password' ? 'text' : 'password';
        btn.textContent = inp.type === 'password' ? '👁️' : '🙈';
    }
    function toggleSetting(id) {
        document.getElementById(id).classList.toggle('on');
        document.getElementById(id).classList.toggle('off');
    }
    function toggleDark() {
        toggleDarkMode();
    }
    @if (TempData["PwError"] != null || TempData["PwSuccess"] != null)
    {
            <text>document.getElementById('edit-expand').classList.add('open');</text>
    }
    // Sync toggle state on page load
    if (localStorage.getItem('libDarkAdmin') === '1') {
        const dt = document.getElementById('darkToggle');
        if (dt) { dt.classList.replace('off', 'on'); }
    }
</script>