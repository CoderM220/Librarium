@model IEnumerable<Librarium.Models.MemberViewModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Members";
    ViewBag.PageName = "Members";
}

<div class="panel">
    <div class="panel-header">
        <span class="panel-title">👥 Members</span>
        <span style="font-size:13px;color:#888;">@Model.Count() registered students</span>
    </div>

    <table>
        <thead>
            <tr>
                <th>Member</th>
                <th>Email</th>
                <th>Registered</th>
                <th>Active Borrows</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div class="due-ava" style="background:linear-gradient(135deg,var(--amber),var(--burgundy));">
                                @m.Student.FullName.Substring(0, Math.Min(2, m.Student.FullName.Length)).ToUpper()
                            </div>
                            <span class="book-t">@m.Student.FullName</span>
                        </div>
                    </td>
                    <td style="color:#888;font-size:13px;">@m.Student.Email</td>
                    <td style="color:#888;font-size:13px;">@m.Student.RegisteredAt.ToString("MMM d, yyyy")</td>
                    <td style="text-align:center;">
                        @if (m.ActiveBorrows > 0)
                        {
                            <span class="badge b-borrow">@m.ActiveBorrows book@(m.ActiveBorrows > 1 ? "s" : "")</span>
                        }
                        else
                        {
                            <span style="color:#aaa;font-size:13px;">—</span>
                        }
                    </td>
                    <td>
                        @if (m.HasOverdue)
                        {
                            <span class="badge" style="background:var(--burgundy);color:#fff;">⚠️ Overdue</span>
                        }
                        else if (m.ActiveBorrows > 0)
                        {
                            <span class="badge b-borrow">Borrowing</span>
                        }
                        else
                        {
                            <span class="badge b-avail">Active</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
