@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Reset Password";
}

<div style="max-width:420px;margin:60px auto;">
    <div style="background:#fff;border:1px solid var(--paper);border-radius:14px;padding:28px 32px;">
        <h4 style="font-family:'Playfair Display',serif;color:var(--ink);margin:0 0 6px;">Reset Password</h4>
        <p style="font-size:13px;color:var(--dust);margin:0 0 20px;">Enter your new password below.</p>

        @if (ViewBag.Error != null)
        {
            <div style="background:rgba(122,32,32,0.08);border:1px solid rgba(122,32,32,0.2);border-radius:8px;padding:10px 14px;font-size:13px;color:var(--burgundy);margin-bottom:14px;">❌ @ViewBag.Error</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">New Password</label>
                <div style="position:relative;">
                    <input class="form-input" id="newPw" name="newPassword" type="password" placeholder="Min 8 characters" style="padding-right:42px;" required />
                    <button type="button" onclick="togglePw('newPw',this)" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:15px;color:var(--dust);padding:0;">👁️</button>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Confirm New Password</label>
                <div style="position:relative;">
                    <input class="form-input" id="conPw" name="confirmPassword" type="password" placeholder="Repeat new password" style="padding-right:42px;" required />
                    <button type="button" onclick="togglePw('conPw',this)" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:15px;color:var(--dust);padding:0;">👁️</button>
                </div>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;margin-top:8px;">Reset Password</button>
        </form>
    </div>
</div>

<script>
    function togglePw(id, btn) {
        var inp = document.getElementById(id);
        inp.type = inp.type === 'password' ? 'text' : 'password';
        btn.textContent = inp.type === 'password' ? '👁️' : '🙈';
    }
</script>