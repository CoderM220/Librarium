@using Microsoft.AspNetCore.Http
@inject Librarium.Models.LibrariumDbContext _db
@{
	var overdueCount = _db.BorrowRecords.Count(r => r.Status == "overdue");
	var pendingBookings = _db.BookingRequests.Count(r => r.Status == "pending");
	var pendingReturns = _db.ReturnRequests.Count(r => r.Status == "pending");
}
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
	<title>Librarium — @ViewBag.Title</title>
	<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
	<link href="~/css/librarium-shared.css" rel="stylesheet" />
</head>
<body>
	<script>if(localStorage.getItem('libDarkAdmin')==='1')document.body.classList.add('dark');</script>
	<div class="sidebar-overlay" id="sidebarOverlay"></div>

	<button class="hamburger hamburger-always" id="hamburgerBtn" aria-label="Toggle menu" style="background:#fff;border:1px solid #E0D0B8;border-radius:8px;width:36px;height:36px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;cursor:pointer;position:fixed;top:16px;left:16px;z-index:190;">
		<span style="display:block;width:16px;height:1.5px;background:#8B5E3C;border-radius:2px;"></span>
		<span style="display:block;width:16px;height:1.5px;background:#8B5E3C;border-radius:2px;"></span>
		<span style="display:block;width:16px;height:1.5px;background:#8B5E3C;border-radius:2px;"></span>
		@if (overdueCount > 0 || pendingBookings > 0 || pendingReturns > 0)
		{
			<span style="position:absolute;top:6px;right:6px;width:8px;height:8px;border-radius:50%;background:#e53935;border:1.5px solid #fff;"></span>
		}
	</button>

	<div style="display:flex;min-height:100vh;">
		<aside class="sidebar">
			<div class="sidebar-logo" style="display:flex;align-items:center;gap:10px;padding-left:16px;">
				<div style="width:32px;height:32px;border-radius:6px;background:#C8832A;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
					<svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
						<rect x="2" y="2" width="10" height="14" rx="1.5" fill="#F5E6D0" />
						<rect x="5" y="2" width="10" height="14" rx="1.5" fill="#E8C98A" opacity="0.6" />
						<line x1="4" y1="6" x2="10" y2="6" stroke="#2C1810" stroke-width="1" stroke-linecap="round" />
						<line x1="4" y1="9" x2="10" y2="9" stroke="#2C1810" stroke-width="1" stroke-linecap="round" />
						<line x1="4" y1="12" x2="8" y2="12" stroke="#2C1810" stroke-width="1" stroke-linecap="round" />
					</svg>
				</div>
				<div>
					<span class="sidebar-logo-name" style="display:block;">Librarium</span>
					<span class="sidebar-logo-role">Admin Panel</span>
				</div>
			</div>
			<nav class="nav">
				<span class="nav-label">Overview</span>
				<a class="nav-item @(ViewBag.PageName == "Home" ? "active" : "")" asp-controller="Admin" asp-action="Index">🏛️ Home</a>
				<a class="nav-item @(ViewBag.PageName == "Books" ? "active" : "")" asp-controller="Admin" asp-action="Books">📚 Books</a>
				<a class="nav-item @(ViewBag.PageName == "Shelves" ? "active" : "")" asp-controller="Admin" asp-action="Shelves">🗂️ Shelves</a>
				<a class="nav-item @(ViewBag.PageName == "Members" ? "active" : "")" asp-controller="Admin" asp-action="Members">👥 Members</a>
				<a class="nav-item @(ViewBag.PageName == "Borrowing" ? "active" : "")" asp-controller="Admin" asp-action="Borrowing">↔️ Borrowing</a>
				<a class="nav-item @(ViewBag.PageName == "Overdue" ? "active" : "")" asp-controller="Admin" asp-action="Overdue">
					⚠️ Overdue
					@if (overdueCount > 0)
					{
						<span style="margin-left:auto;width:8px;height:8px;border-radius:50%;background:#e53935;display:inline-block;flex-shrink:0;"></span>
					}
				</a>
				<a class="nav-item @(ViewBag.PageName == "BookingRequests" ? "active" : "")" asp-controller="Admin" asp-action="BookingRequests">
					📋 Booking Requests
					@if (pendingBookings > 0)
					{
						<span style="margin-left:auto;width:8px;height:8px;border-radius:50%;background:#e53935;display:inline-block;flex-shrink:0;"></span>
					}
				</a>
				<a class="nav-item @(ViewBag.PageName == "ReturnRequests" ? "active" : "")" asp-controller="Admin" asp-action="ReturnRequests">
					📬 Return Requests
					@if (pendingReturns > 0)
					{
						<span style="margin-left:auto;width:8px;height:8px;border-radius:50%;background:#e53935;display:inline-block;flex-shrink:0;"></span>
					}
				</a>
				<a class="nav-item @(ViewBag.PageName == "Fines" ? "active" : "")" asp-controller="Admin" asp-action="Fines">💰 Fines</a>
				<span class="nav-label">Account</span>
				<a class="nav-item @(ViewBag.PageName == "Profile" ? "active" : "")" asp-controller="Admin" asp-action="Profile">👤 Profile</a>
			</nav>
			<div class="sidebar-footer">
				<div class="user-pill">
					<div class="user-ava">@(Context.Session.GetString("AdminName")?.Substring(0, 2).ToUpper())</div>
					<div>
						<div class="user-name">@Context.Session.GetString("AdminName")</div>
						<div class="user-role-badge">ADMIN</div>
					</div>
				</div>
				<a asp-controller="Auth" asp-action="Logout" class="logout-btn">⬅️ Logout</a>
			</div>
		</aside>

		<main style="flex:1;margin-left:0;">
			<div class="topbar" style="padding-left:68px;">
				<div class="topbar-title">@ViewBag.PageName</div>
				@if (TempData["Success"] != null)
				{
					<span style="background:var(--sage);color:#fff;padding:8px 14px;border-radius:8px;font-size:13px;">✅ @TempData["Success"]</span>
				}
				@if (TempData["Error"] != null)
				{
					<span style="background:var(--burgundy);color:#fff;padding:8px 14px;border-radius:8px;font-size:13px;">❌ @TempData["Error"]</span>
				}
			</div>
			<div class="content">
				@RenderBody()
			</div>
		</main>
	</div>

	<script>
		const hamburgerBtn = document.getElementById('hamburgerBtn');
		const sidebar = document.querySelector('.sidebar');
		const overlay = document.getElementById('sidebarOverlay');

		function openMenu() {
			sidebar.classList.add('open');
			overlay.classList.add('open');
			hamburgerBtn.classList.add('open');
			document.body.style.overflow = 'hidden';
		}

		function closeMenu() {
			sidebar.classList.remove('open');
			overlay.classList.remove('open');
			hamburgerBtn.classList.remove('open');
			document.body.style.overflow = '';
		}

		hamburgerBtn.addEventListener('click', () => {
			sidebar.classList.contains('open') ? closeMenu() : openMenu();
		});

		overlay.addEventListener('click', closeMenu);

		document.querySelectorAll('.nav-item').forEach(link => {
			link.addEventListener('click', () => {
				if (window.innerWidth <= 768) closeMenu();
			});
		});
		// dark mode
		function toggleDarkMode() {
		   const on = document.body.classList.toggle('dark');
		   localStorage.setItem('libDarkAdmin', on ? '1' : '0');
		   // sync toggle UI if on profile page
		   const el = document.getElementById('darkToggle');
		   if (el) { el.classList.toggle('on', on); el.classList.toggle('off', !on); }
		}
	</script>
</body>
</html>
