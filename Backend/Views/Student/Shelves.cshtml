@model IEnumerable<Librarium.Models.Shelf>
@{
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewBag.Title = "Shelves";
    ViewBag.PageName = "Shelves";

    var shelfList = Model.ToList();
    int totalAlmirahs = shelfList.Count(s => s.ShelfType == "almirah");
    int totalRacks = shelfList.Count(s => s.ShelfType == "rack");
    int booksStored = shelfList.Sum(s => s.Books.Count);
    int emptyShelves = shelfList.Count(s => s.Books.Count == 0);
}

<style>
    @@media (max-width: 768px) {
        .shelves-layout {
            flex-direction: column !important;
        }
        .shelf-detail-panel {
            width: 100% !important;
        }
        .stats-row {
            grid-template-columns: repeat(2, 1fr) !important;
        }
    }
</style>

<div class="stats-row" style="margin-bottom:16px;">
    <div class="stat-card sc-amber">
        <div class="stat-ico">🗄️</div>
        <div class="stat-val">@totalAlmirahs</div>
        <div class="stat-lbl">Total Almirahs</div>
    </div>
    <div class="stat-card sc-burg">
        <div class="stat-ico">📦</div>
        <div class="stat-val">@totalRacks</div>
        <div class="stat-lbl">Total Racks</div>
    </div>
    <div class="stat-card sc-sage">
        <div class="stat-ico">📚</div>
        <div class="stat-val">@booksStored</div>
        <div class="stat-lbl">Books Stored</div>
    </div>
    <div class="stat-card sc-dust">
        <div class="stat-ico">🔲</div>
        <div class="stat-val">@emptyShelves</div>
        <div class="stat-lbl">Empty Shelves</div>
    </div>
</div>

<div class="shelves-layout" style="display:flex;gap:16px;align-items:flex-start;">

    <div class="panel" style="flex:1;min-width:0;">
        <div class="panel-header">
            <span class="panel-title">🗺️ Library Floor Plan</span>
            <div style="display:flex;gap:12px;align-items:center;font-size:12px;flex-wrap:wrap;">
                <span style="display:flex;align-items:center;gap:4px;">
                    <span style="width:12px;height:12px;border-radius:2px;background:var(--amber);display:inline-block;"></span> Almirah
                </span>
                <span style="display:flex;align-items:center;gap:4px;">
                    <span style="width:12px;height:12px;border-radius:2px;background:var(--sage);display:inline-block;"></span> Rack
                </span>
                <span style="display:flex;align-items:center;gap:4px;">
                    <span style="width:12px;height:12px;border-radius:2px;background:var(--burgundy);display:inline-block;"></span> Selected
                </span>
            </div>
        </div>
        <div style="overflow-x:auto;">
            <div id="floorGrid" style="
                display:grid;
                grid-template-columns:repeat(10,1fr);
                grid-template-rows:repeat(10,44px);
                gap:3px;
                padding:8px;
                min-width:300px;">
            </div>
        </div>
    </div>

    <div class="panel shelf-detail-panel" style="width:260px;flex-shrink:0;min-height:300px;display:flex;flex-direction:column;">
        <div class="panel-header" style="border-bottom:1px solid var(--border);padding-bottom:10px;margin-bottom:10px;">
            <div>
                <div id="detName" style="font-size:15px;font-weight:600;color:var(--text-primary);">No shelf selected</div>
                <div id="detSub" style="font-size:12px;color:var(--text-muted);margin-top:2px;">Tap any shelf on the map</div>
                <div id="detBadge" style="margin-top:6px;"></div>
            </div>
        </div>
        <div id="bookList" style="flex:1;overflow-y:auto;padding:0 4px;">
            <div style="font-size:12px;color:var(--text-muted);text-align:center;padding:20px 0;">
                Select a shelf to see its books
            </div>
        </div>
    </div>

</div>

<div id="detailModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:1000;align-items:center;justify-content:center;">
    <div style="background:var(--cream);border-radius:16px;padding:28px 32px;width:480px;max-width:95vw;box-shadow:0 8px 40px rgba(0,0,0,0.2);position:relative;max-height:90vh;overflow-y:auto;">
        <button onclick="closeModal()" style="position:absolute;top:14px;right:16px;background:none;border:none;font-size:20px;cursor:pointer;color:var(--text-muted);">✕</button>
        <div id="modalContent"></div>
    </div>
</div>

@Html.AntiForgeryToken()
<div id="toast" style="display:none;position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#333;color:#fff;padding:12px 24px;border-radius:8px;font-size:14px;z-index:9999;text-align:center;"></div>

<script>
    const shelves = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        shelfList.Select(s => new {
            id = s.Id,
            code = s.ShelfCode,
            type = s.ShelfType,
            col = s.GridCol,
            row = s.GridRow,
            books = s.Books.Select(b => new {
                id = b.Id,
                title = b.Title,
                author = b.Author,
                status = b.Status
            }).ToList()
        })
    ));

    let selectedId = null;
    const isMobile = () => window.innerWidth <= 768;

    function renderGrid() {
        const grid = document.getElementById('floorGrid');
        grid.innerHTML = '';

       grid.style.gridTemplateColumns = 'repeat(10,1fr)';
       grid.style.gridTemplateRows = 'repeat(10,40px)';
       grid.style.gridAutoRows = '';

        shelves.forEach(s => {
            const hasBooks = s.books && s.books.length > 0;
            const isSelected = selectedId === s.id;

            let bg, border, color;
            if (isSelected) {
                bg = 'var(--burgundy)'; border = 'var(--burgundy)'; color = '#fff';
            } else if (hasBooks) {
                bg = s.type === 'rack' ? 'var(--sage)' : 'var(--amber)';
                border = s.type === 'rack' ? 'var(--sage)' : 'var(--amber)';
                color = '#fff';
            } else {
                bg = s.type === 'rack' ? 'rgba(107,142,107,0.15)' : 'rgba(184,142,74,0.15)';
                border = s.type === 'rack' ? 'rgba(107,142,107,0.4)' : 'rgba(184,142,74,0.4)';
                color = 'var(--text-muted)';
            }

            const cell = document.createElement('div');
            const colStyle = `grid-column:${s.col};grid-row:${s.row};`;
            cell.style.cssText = `
                ${colStyle}
                background:${bg};border:1.5px solid ${border};border-radius:4px;
                display:flex;flex-direction:column;align-items:center;justify-content:center;
                cursor:pointer;font-size:8px;font-weight:600;color:${color};
                line-height:1.3;transition:opacity 0.15s;
            `;
            cell.innerHTML = `
                <span>${s.code}</span>
                ${hasBooks ? `<span style="font-size:7px;opacity:0.85;">${s.books.length}bk</span>` : ''}
            `;
            cell.onmouseover = () => { if (selectedId !== s.id) cell.style.opacity = '0.75'; };
            cell.onmouseout = () => { cell.style.opacity = '1'; };
            cell.onclick = () => selectShelf(s.id);
            grid.appendChild(cell);
        });
    }

    function selectShelf(id) {
        selectedId = id;
        renderGrid();

        const s = shelves.find(x => x.id === id);
        const typeName = s.type === 'rack' ? 'Rack' : 'Almirah';
        const badgeColor = s.type === 'rack' ? 'var(--sage)' : 'var(--amber)';

        document.getElementById('detName').textContent = typeName + ' ' + s.code;
        document.getElementById('detSub').textContent = s.books.length + ' book' + (s.books.length !== 1 ? 's' : '') + ' stored here';
        document.getElementById('detBadge').innerHTML = `
            <span style="display:inline-block;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:500;
                background:${badgeColor}22;color:${badgeColor};border:1px solid ${badgeColor};">
                ${typeName}
            </span>`;

        if (s.books.length === 0) {
            document.getElementById('bookList').innerHTML =
                '<div style="font-size:12px;color:var(--text-muted);text-align:center;padding:20px 0;">No books stored here yet</div>';
        } else {
            document.getElementById('bookList').innerHTML = s.books.map(b => `
                <div style="padding:10px 0;border-bottom:1px solid var(--border);cursor:pointer;" onclick="viewDetail(${b.id})">
                    <div style="font-size:13px;font-weight:500;color:var(--text-primary);">${b.title}</div>
                    <div style="font-size:11px;color:var(--text-muted);">${b.author}</div>
                    <span style="font-size:10px;padding:1px 7px;border-radius:10px;margin-top:3px;display:inline-block;
                        background:${b.status === 'available' ? 'rgba(107,142,107,0.15)' : 'rgba(139,60,60,0.15)'};
                        color:${b.status === 'available' ? 'var(--sage)' : 'var(--burgundy)'};">
                        ${b.status}
                    </span>
                </div>`).join('');
        }

        // On mobile, scroll down to detail panel after selecting
        if (isMobile()) {
            document.querySelector('.shelf-detail-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    }

    function viewDetail(id) {
        fetch(`/Student/BookDetail?id=${id}`)
            .then(r => r.json())
            .then(b => {
                const shelfInfo = b.shelfCode
                    ? `<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:12px;background:rgba(184,142,74,0.15);color:var(--amber);border:1px solid var(--amber);">
                        📍 ${b.shelfType === 'rack' ? 'Rack' : 'Almirah'} ${b.shelfCode}
                       </span>`
                    : `<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:12px;background:rgba(0,0,0,0.06);color:var(--text-muted);border:1px solid var(--border);">
                        No shelf assigned
                       </span>`;

                document.getElementById('modalContent').innerHTML = `
                    <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px;">
                        <div style="font-size:48px;">${b.emoji}</div>
                        <div>
                            <div style="font-size:18px;font-weight:700;color:var(--text-primary);">${b.title}</div>
                            <div style="font-size:13px;color:var(--text-muted);margin-top:2px;">${b.author}</div>
                            <div style="margin-top:6px;">${shelfInfo}</div>
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;">
                        <div style="background:var(--bg-secondary);border-radius:8px;padding:10px 14px;">
                            <div style="font-size:10px;color:var(--text-muted);margin-bottom:2px;">YEAR</div>
                            <div style="font-size:13px;font-weight:500;">${b.year || '—'}</div>
                        </div>
                        <div style="background:var(--bg-secondary);border-radius:8px;padding:10px 14px;">
                            <div style="font-size:10px;color:var(--text-muted);margin-bottom:2px;">ISBN</div>
                            <div style="font-size:13px;font-weight:500;">${b.isbn || '—'}</div>
                        </div>
                        <div style="background:var(--bg-secondary);border-radius:8px;padding:10px 14px;">
                            <div style="font-size:10px;color:var(--text-muted);margin-bottom:2px;">COPIES</div>
                            <div style="font-size:13px;font-weight:500;">${b.availableCopies} / ${b.copies}</div>
                        </div>
                    </div>
                    <div style="margin-bottom:14px;">
                        <span style="padding:3px 12px;border-radius:20px;font-size:12px;font-weight:500;
                            background:${b.status === 'available' ? 'rgba(107,142,107,0.15)' : 'rgba(139,60,60,0.15)'};
                            color:${b.status === 'available' ? 'var(--sage)' : 'var(--burgundy)'};">
                            ${b.status === 'available' ? '✅ Available' : '📤 Borrowed'}
                        </span>
                    </div>
                    <div style="display:flex;gap:8px;margin-top:16px;flex-wrap:wrap;">
                        <button onclick="requestBookFromModal(${b.id}, '${b.title.replace(/'/g, "\\'")}')"
                                class="btn btn-primary" style="font-size:13px;">📖 Request Book</button>
                        <button onclick="closeModal()" class="btn btn-outline" style="font-size:13px;">Close</button>
                    </div>`;

                document.getElementById('detailModal').style.display = 'flex';
            });
    }

    function closeModal() {
        document.getElementById('detailModal').style.display = 'none';
    }

    document.getElementById('detailModal').addEventListener('click', function(e) {
        if (e.target === this) closeModal();
    });

    function requestBookFromModal(bookId, title) {
        fetch('/Student/RequestBooking', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
            },
            body: 'bookId=' + bookId
        })
        .then(r => r.json())
        .then(data => { closeModal(); showToast(data.message, data.success); })
        .catch(() => showToast('Something went wrong.', false));
    }

    function showToast(msg, success) {
        var t = document.getElementById('toast');
        t.textContent = msg;
        t.style.background = success ? '#2d6a4f' : '#c0392b';
        t.style.display = 'block';
        setTimeout(() => t.style.display = 'none', 3500);
    }

    window.addEventListener('resize', renderGrid);
    renderGrid();
</script>
